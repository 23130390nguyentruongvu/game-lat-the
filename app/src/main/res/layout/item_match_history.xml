<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- UC10 - 10.1.7: Hàng đầu - Tên đối thủ + Kết quả -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- 10.1.5: Tên đối thủ -->
            <TextView
                android:id="@+id/tvOpponentName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Vs: Opponent Name"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/black" />

            <!-- 10.1.5: Kết quả (WIN/LOSE) -->
            <TextView
                android:id="@+id/tvResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thắng"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@android:color/holo_green_dark"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/bg_result_badge" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="8dp" />

        <!-- UC10 - 10.1.5: Hàng 2 - Độ khó + Vai trò -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <!-- 10.1.5: Độ khó -->
            <TextView
                android:id="@+id/tvDifficulty"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Độ khó: EASY"
                android:textSize="13sp"
                android:textColor="@android:color/darker_gray" />

            <!-- 10.1.4: Vai trò (HOST/GUEST) -->
            <TextView
                android:id="@+id/tvRole"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Vai trò: HOST"
                android:textSize="13sp"
                android:textColor="@android:color/darker_gray" />

        </LinearLayout>

        <!-- UC10 - 10.1.5: Hàng 3 - So sánh điểm -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <!-- 10.1.5: Điểm -->
            <TextView
                android:id="@+id/tvScore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Điểm: 10 vs 8"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@android:color/holo_blue_dark" />

            <!-- 10.1.5: Thời gian chơi -->
            <TextView
                android:id="@+id/tvPlayDuration"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Thời gian: 2:30"
                android:textSize="13sp"
                android:textColor="@android:color/darker_gray"
                android:textAlignment="textEnd" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="8dp" />

        <!-- UC10 - 10.1.5: Hàng 4 - Thời gian + Mã phòng -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- 10.1.5: Thời gian tạo phòng -->
            <TextView
                android:id="@+id/tvCreateAt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="25/06/2026 14:30"
                android:textSize="12sp"
                android:textColor="@android:color/darker_gray" />

            <!-- 10.1.3: Mã phòng -->
            <TextView
                android:id="@+id/tvRoomCode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mã phòng: ABC123"
                android:textSize="12sp"
                android:textColor="@android:color/darker_gray"
                android:textAlignment="textEnd" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>