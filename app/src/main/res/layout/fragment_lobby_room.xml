<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.view.home_screen.multi.LobbyRoomFragment">

    <TextView
        android:id="@+id/tv_label_lobby_room"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:textAppearance="@style/TextAppearance.AppCompat.Display1"
        android:text=""
        android:textAlignment="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_show_roomcode_lobby_room"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textAlignment="center"
        android:textAppearance="@style/TextAppearance.AppCompat.Title"
        android:text=""

        app:layout_constraintEnd_toEndOf="@+id/tv_label_lobby_room"
        app:layout_constraintStart_toStartOf="@+id/tv_label_lobby_room"
        app:layout_constraintTop_toBottomOf="@+id/tv_label_lobby_room" />

    <Button
        android:id="@+id/btn_start_game_lobby_room"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bắt đầu ván đấu"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideline3" />

    <TextView
        android:id="@+id/tv_label_name_host_lobby_room"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="90dp"
        android:layout_marginStart="16dp"

        android:textAppearance="@style/TextAppearance.AppCompat.Medium"
        app:layout_constraintStart_toStartOf="@+id/tv_show_roomcode_lobby_room"
        app:layout_constraintTop_toBottomOf="@+id/tv_show_roomcode_lobby_room" />

    <TextView
        android:id="@+id/tv_label_name_guest_looby_room"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textAppearance="@style/TextAppearance.AppCompat.Medium"
        app:layout_constraintStart_toStartOf="@+id/tv_label_name_host_lobby_room"
        app:layout_constraintTop_toBottomOf="@+id/tv_label_name_host_lobby_room" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline3"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.6" />

    <Button
        android:id="@+id/btn_leave_room_lobby_room"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Rời phòng"
        app:layout_constraintEnd_toEndOf="@+id/btn_start_game_lobby_room"
        app:layout_constraintStart_toStartOf="@+id/btn_start_game_lobby_room"
        app:layout_constraintTop_toBottomOf="@+id/btn_start_game_lobby_room" />
</androidx.constraintlayout.widget.ConstraintLayout>