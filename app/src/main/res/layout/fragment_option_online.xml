<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="vertical"
    tools:context=".ui.view.home_screen.multi.OptionOnlineFragment"
    android:padding="24dp">

    <Button
        android:id="@+id/btn_create_room_option_online"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tạo phòng mới" />

    <Button
        android:id="@+id/btn_entry_room_option_online"
        android:layout_width="match_parent"
        android:layout_marginTop="12dp"
        android:layout_height="wrap_content"
        android:text="Vào phòng bằng mã" />
</LinearLayout>